# Copier ce fichier en .env (a la racine du projet) et adapter si besoin.
# .env n'est pas versionne (voir .gitignore). Charge automatiquement par
# mlproject/config.py.

# URI du serveur de tracking MLflow
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Nom de l'experience MLflow utilisee par les scripts d'entrainement
MLFLOW_EXPERIMENT=classification-baseline

# Description de l'experience (affichee dans l'UI MLflow)
MLFLOW_EXPERIMENT_DESCRIPTION=Projet de classification - cours MLOps

# Tags de l'experience, format cle=valeur separes par des virgules
MLFLOW_EXPERIMENT_TAGS=course=mlops

# Nom du modele dans le MLflow Model Registry
MODEL_NAME=classifier

# Seuils de la porte qualite (mlproject.evaluate) : modele rejete si en dessous
EVAL_ROC_AUC_MIN=0.65
EVAL_F1_MIN=0.55

# URL de l'API FastAPI (client de previsions, DAG daily_predictions)
API_URL=http://127.0.0.1:8000
